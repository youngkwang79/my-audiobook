{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "app/api/**/*": {
      "excludeFiles": "{ffmpeg.exe,*.exe,*.py,*.mp3,*.zip,_temp_plan_*/**/*,무림북_*/**/*,무명지협/**/*,scripts/**/*,node_modules/{@next/swc-win32-x64-msvc}/**/*}"
    }
  },
  "regions": [
    "icn1"
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/push-daily",
      "schedule": "0 8 * * *"
    }
  ]
}