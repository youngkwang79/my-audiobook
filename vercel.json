{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "app/api/admin/content-factory/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/admin/r2-download/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    }
  },

  "regions": [
    "icn1"
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/push-daily",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/billing-schedule",
      "schedule": "0 0 * * *"
    }
  ]
}
